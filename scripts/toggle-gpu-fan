#!/bin/sh
# Toggle GPU fan between Default (temperature curve) and Gaming (100%) LACT profiles.
# Direct pwm writes are pointless here — lactd re-applies its config every 5s.

current=$(lact cli profile get 2>/dev/null)

if [ "$current" = "Gaming" ]; then
    lact cli profile set Default >/dev/null 2>&1
    notify-send -t 2000 "GPU Fan: CURVE" "Temperature-driven curve active" 2>/dev/null || true
else
    lact cli profile set Gaming >/dev/null 2>&1
    notify-send -t 2000 "GPU Fan: 100%" "Full speed (Gaming profile)" 2>/dev/null || true
fi
