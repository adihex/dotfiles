#!/usr/bin/env python3
import subprocess

try:
    out = subprocess.check_output(["nmcli", "-t", "-f", "TYPE,STATE,CONNECTION", "device"], timeout=2).decode()
    lines = [l.split(":") for l in out.strip().split("\n") if ":" in l]
    
    wifi_conn = next((l[2] for l in lines if l[0] == "wifi" and l[1] == "connected"), None)
    eth_conn = next((l[2] for l in lines if l[0] == "ethernet" and l[1] == "connected"), None)

    if eth_conn:
        print(f'type=ethernet name="{eth_conn}" icon="󰈀"')
    elif wifi_conn:
        print(f'type=wifi name="{wifi_conn}" icon="󰤨"')
    else:
        print('type=offline name="Offline" icon="󰤭"')
except Exception:
    print('type=offline name="Offline" icon="󰤭"')
