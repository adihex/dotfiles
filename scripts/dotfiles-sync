#!/bin/sh
# dotfiles-sync — commit & push ~/dotfiles if anything changed.
# Run manually or via dotfiles-sync.timer (systemd --user).

cd "$HOME/dotfiles" || exit 1

git add -A
if git diff --cached --quiet; then
    exit 0  # nothing to do
fi

msg="auto-sync: $(date '+%Y-%m-%d %H:%M')"
git commit -m "$msg" >/dev/null || exit 1

if git push -q origin HEAD 2>/tmp/dotfiles-sync.err; then
    notify-send -t 2000 "dotfiles synced" "$msg" 2>/dev/null || true
else
    notify-send -u critical "dotfiles sync failed" "$(tail -1 /tmp/dotfiles-sync.err)" 2>/dev/null || true
    exit 1
fi
